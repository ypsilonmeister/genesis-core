# =============================================================================
# .env.example — 環境変数のテンプレート
#
# 使い方:
#   cp .env.example .env
#   その後、各 API キーを記入
#
# .env は .gitignore 済み (絶対にコミットしないこと)
# =============================================================================

# Anthropic Claude API (Tier 1 / Tier 2 の修復案生成、Week 2 から必要)
ANTHROPIC_API_KEY=

# Google Gemini API (攻撃 AI、Week 3 から必要)
GEMINI_API_KEY=

# 使用モデル (省略可、未設定時はコード内デフォルト)
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash

# ログレベル (省略可)
RUST_LOG=info,orchestrator=debug

# CMP ループのトリガ閾値 (省略可、デフォルトは仕様 §5.1 / §5.2)
TIER1_TRIGGER_COUNT=3
TIER2_TRIGGER_COUNT=5

# 攻撃 AI の解放 Phase (A/B/C/D)
ATTACK_PHASE=A
