# =============================================================================
# .env.example — 環境変数のテンプレート
#
# 使い方:
#   cp .env.example .env
#   その後、各 API キーを記入
#
# .env は .gitignore 済み (絶対にコミットしないこと)
# =============================================================================

# AI バックエンド選択 (cli = CLI サブプロセス / api = HTTP API キー)
# デフォルトはいずれも cli。CLI がインストール済みであれば API キー不要。
CLAUDE_BACKEND=cli
GEMINI_BACKEND=cli

# CLI バイナリパス (省略可、PATH 上にあれば不要)
# CLAUDE_BINARY=claude
# GEMINI_BINARY=gemini

# Anthropic Claude API キー (CLAUDE_BACKEND=api のときのみ必要)
ANTHROPIC_API_KEY=

# Google Gemini API キー (GEMINI_BACKEND=api のときのみ必要)
GEMINI_API_KEY=

# 使用モデル (省略可、未設定時はコード内デフォルト)
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash

# ログレベル (省略可)
RUST_LOG=info,orchestrator=debug

# CMP ループのトリガ閾値 (省略可、デフォルトは仕様 §5.1 / §5.2)
TIER1_TRIGGER_COUNT=3
TIER2_TRIGGER_COUNT=5
# 同一モジュールを何回 Tier 1 修復したら UNKNOWN_PATTERN にエスカレートするか
TIER1_MAX_REPAIRS=2

# 攻撃 AI の解放 Phase (A/B/C/D)
# Week 1-3: A, Week 4+: D (累積式 — D を指定すると A〜D 全例が提示される)
ATTACK_PHASE=D

# 攻撃インターバル (秒) — デフォルト: 20〜60 分 (30日連続運転向け)
ATTACK_INTERVAL_MIN_SECS=1200
ATTACK_INTERVAL_MAX_SECS=3600

# 把握テストを無効化したい場合 (デフォルト: 有効)
# COMPREHENSION_TEST_ENABLED=false
