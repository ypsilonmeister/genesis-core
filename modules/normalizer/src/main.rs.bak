// =============================================================================
// # CMP Module Charter
//
// What:
//   入力文字列を正規化して後続モジュールに渡す(空白除去のみ)。
//
// Invariants:
//   - 入力文字列を破壊的に変更しない(元の入力はログに残す)
//   - 空文字列を受け取った場合はエラーを返す
//
// Boundaries:
//   - 依存先: なし
//   - 被依存先: tokenizer
//
// Extensible:
//   - 正規化ルールの追加 (全角→半角変換、不可視文字除去、etc.)
//
// Why:
//   後続モジュールが純粋な解析に集中できるよう、表層的なノイズを除去する。
//
// Tier 1 で AI が改変するときは、上記 Invariants と Boundaries を絶対に
// 破らないこと。What の範囲を超える変更は Tier 2 として扱う。
// =============================================================================

// v1 実装範囲:
//   連続空白を単一空白に圧縮、前後空白をトリム。それ以外は素通し。

use crate::compat::UnixListener;
use anyhow::Result;
use serde::{Deserialize, Serialize};
use std::env;
use tokio::io::{AsyncBufReadExt, AsyncWriteExt};

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModuleRequest {
    pub request_id: String,
    pub input: String,
    pub timestamp: chrono::DateTime<chrono::Utc>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModuleResponse {
    pub request_id: String,
    pub output: Option<String>,
    pub error: Option<ModuleError>,
    pub processing_ms: u64,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModuleError {
    pub code: String,
    pub message: String,
    pub input_position: Option<usize>,
}

#[derive(Debug)]
pub enum NormalizeError {
    EmptyInput,
    UnknownPattern(String),
}

#[tokio::main]
async fn main() -> Result<()> {
    init_tracing();
    tracing::info!("normalizer booting (v1)");

    let socket_path = env::args()
        .nth(1)
        .unwrap_or_else(|| "/tmp/genesis-core/normalizer.sock".to_string());

    // 以前のソケットファイルを削除
    let _ = std::fs::remove_file(&socket_path);
    // ディレクトリ作成
    if let Some(parent) = std::path::Path::new(&socket_path).parent() {
        std::fs::create_dir_all(parent)?;
    }

    let listener = UnixListener::bind(&socket_path)?;
    tracing::info!("Listening on {}", socket_path);

    loop {
        let (stream, _) = listener.accept().await?;
        tokio::spawn(async move {
            let (reader, mut writer) = stream.split();
            let mut reader = tokio::io::BufReader::new(reader);
            let mut line = String::new();

            if let Ok(n) = reader.read_line(&mut line).await {
                if n == 0 {
                    return;
                }
                let start = std::time::Instant::now();
                let request: ModuleRequest = match serde_json::from_str(&line) {
                    Ok(req) => req,
                    Err(e) => {
                        tracing::error!("Failed to parse request: {}", e);
                        return;
                    }
                };

                let (output, error) = match normalize(&request.input) {
                    Ok(out) => (Some(out), None),
                    Err(e) => {
                        let (code, message) = match e {
                            NormalizeError::EmptyInput => ("SYNTAX_ERROR".to_string(), "Empty input".to_string()),
                            NormalizeError::UnknownPattern(msg) => ("UNKNOWN_PATTERN".to_string(), msg),
                        };
                        (None, Some(ModuleError { code, message, input_position: None }))
                    }
                };

                let response = ModuleResponse {
                    request_id: request.request_id,
                    output,
                    error,
                    processing_ms: start.elapsed().as_millis() as u64,
                };

                if let Ok(payload) = serde_json::to_vec(&response) {
                    let mut payload = payload;
                    payload.push(b'\n');
                    let _ = writer.write_all(&payload).await;
                }
            }
        });
    }
}

/// 連続空白を単一空白に圧縮し、前後空白をトリムする。
/// 元の入力は破壊しない(参照を借りるだけ)。
/// 空文字列の場合はエラーを返す。
/// 未知のパターン(**, 関数呼び出しなど)を検出した場合もエラーを返す。
pub fn normalize(input: &str) -> Result<String, NormalizeError> {
    if input.trim().is_empty() {
        return Err(NormalizeError::EmptyInput);
    }

    detect_unknown_patterns(input)?;

    Ok(input.split_whitespace().collect::<Vec<_>>().join(" "))
}

/// 未知のパターンを検出する。
fn detect_unknown_patterns(input: &str) -> Result<(), NormalizeError> {
    // Check for caret exponentiation (^)
    if input.contains('^') {
        return Err(NormalizeError::UnknownPattern(
            "caret exponentiation (^) not supported".to_string(),
        ));
    }

    // Check for floor division (//)
    if input.contains("//") {
        return Err(NormalizeError::UnknownPattern(
            "floor division (//) not supported".to_string(),
        ));
    }

    // Check for decimal numbers (digit.digit pattern)
    let chars: Vec<char> = input.chars().collect();
    for i in 1..chars.len() - 1 {
        if chars[i] == '.' && chars[i - 1].is_ascii_digit() && chars[i + 1].is_ascii_digit() {
            return Err(NormalizeError::UnknownPattern(
                "decimal numbers not supported".to_string(),
            ));
        }
    }

    // Check for infinity symbol
    if input.contains('∞') {
        return Err(NormalizeError::UnknownPattern(
            "infinity symbol (∞) not supported".to_string(),
        ));
    }

    // Check for pi symbol
    if input.contains('π') {
        return Err(NormalizeError::UnknownPattern(
            "pi symbol (π) not supported".to_string(),
        ));
    }

    // Check for exponentiation operator (**)
    if input.contains("**") {
        return Err(NormalizeError::UnknownPattern(
            "exponentiation operator (**) not supported".to_string(),
        ));
    }

    // Check for function calls (sqrt, log, sin, cos, tan, exp, ln)
    let functions = ["sqrt", "log", "sin", "cos", "tan", "exp", "ln"];
    for func in &functions {
        // Look for function name followed by optional whitespace and opening paren
        let pattern = format!("{}(", func);
        if input.contains(&pattern) {
            return Err(NormalizeError::UnknownPattern(format!(
                "function {} not supported",
                func
            )));
        }
        // Also check with whitespace before paren
        let pattern_with_space = format!("{} (", func);
        if input.contains(&pattern_with_space) {
            return Err(NormalizeError::UnknownPattern(format!(
                "function {} not supported",
                func
            )));
        }
    }

    Ok(())
}

fn init_tracing() {
    use tracing_subscriber::EnvFilter;
    let filter = EnvFilter::try_from_default_env()
        .unwrap_or_else(|_| EnvFilter::new("info,normalizer=debug"));
    tracing_subscriber::fmt().with_env_filter(filter).init();
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn collapses_whitespace() {
        assert_eq!(normalize("3  +\n5 *  2").unwrap(), "3 + 5 * 2");
    }

    #[test]
    fn trims_edges() {
        assert_eq!(normalize("  3 + 5  ").unwrap(), "3 + 5");
    }

    #[test]
    fn empty_input_returns_error() {
        // Charter: 空文字列を受け取った場合はエラーを返す
        assert!(normalize("").is_err());
        assert!(normalize("   ").is_err());
    }

    #[test]
    fn rejects_exponentiation_operator() {
        assert!(matches!(normalize("10**5"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("10**5 / 2**3"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn rejects_sqrt_function() {
        assert!(matches!(normalize("sqrt(2)"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("sqrt(2) + log(10)"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn rejects_trigonometric_functions() {
        assert!(matches!(normalize("sin(90)"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("sin(90) * 0"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("cos(0)"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn rejects_log_function() {
        assert!(matches!(normalize("log(10)"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn rejects_caret_exponentiation() {
        assert!(matches!(normalize("2^2"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("2^2 + log(200)"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn rejects_floor_division() {
        assert!(matches!(normalize("200 // 3"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("10 // 2 + 5"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn rejects_decimal_numbers() {
        assert!(matches!(normalize("2.5"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("10 / (5 + 2.5) * 0.1"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("3.14159"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn rejects_infinity_symbol() {
        assert!(matches!(normalize("∞ + 1"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn rejects_pi_symbol() {
        assert!(matches!(normalize("π * 2"), Err(NormalizeError::UnknownPattern(_))));
        assert!(matches!(normalize("π * (3.14159 / 2)"), Err(NormalizeError::UnknownPattern(_))));
    }

    #[test]
    fn accepts_valid_arithmetic() {
        assert_eq!(normalize("( 1 + 2 ) * ( 3 - 5 )").unwrap(), "( 1 + 2 ) * ( 3 - 5 )");
        assert_eq!(normalize("10 / 5 + 3").unwrap(), "10 / 5 + 3");
    }
}

pub mod compat {
    #[cfg(windows)]
    pub use windows::*;

    #[cfg(unix)]
    pub use tokio::net::{UnixListener, UnixStream};

    #[cfg(windows)]
    mod windows {
        use std::net::SocketAddr;
        use std::path::Path;
        use std::pin::Pin;
        use std::task::{Context, Poll};
        use tokio::io::{AsyncRead, AsyncWrite, ReadBuf};
        use tokio::net::{TcpListener, TcpStream};

        fn path_to_port(path: impl AsRef<Path>) -> u16 {
            use std::collections::hash_map::DefaultHasher;
            use std::hash::{Hash, Hasher};
            let mut hasher = DefaultHasher::new();
            path.as_ref().to_string_lossy().hash(&mut hasher);
            let hash = hasher.finish();
            (49152 + (hash % 16384)) as u16
        }

        pub struct UnixListener {
            inner: TcpListener,
        }

        impl UnixListener {
            pub fn bind(path: impl AsRef<Path>) -> std::io::Result<Self> {
                let port = path_to_port(path);
                let addr = SocketAddr::from(([127, 0, 0, 1], port));
                let std_listener = std::net::TcpListener::bind(addr)?;
                std_listener.set_nonblocking(true)?;
                let inner = TcpListener::from_std(std_listener)?;
                Ok(Self { inner })
            }

            pub async fn accept(&self) -> std::io::Result<(UnixStream, SocketAddr)> {
                let (stream, addr) = self.inner.accept().await?;
                Ok((UnixStream { inner: stream }, addr))
            }
        }

        pub struct UnixStream {
            inner: TcpStream,
        }

        impl UnixStream {
            pub async fn connect(path: impl AsRef<Path>) -> std::io::Result<Self> {
                let port = path_to_port(path);
                let addr = SocketAddr::from(([127, 0, 0, 1], port));
                let inner = TcpStream::connect(addr).await?;
                Ok(Self { inner })
            }

            pub fn split(self) -> (tokio::io::ReadHalf<Self>, tokio::io::WriteHalf<Self>) {
                tokio::io::split(self)
            }
        }

        // Standard poll_read matching Tokio's trait
        impl AsyncRead for UnixStream {
            fn poll_read(
                mut self: Pin<&mut Self>,
                cx: &mut Context<'_>,
                buf: &mut ReadBuf<'_>,
            ) -> Poll<std::io::Result<()>> {
                Pin::new(&mut self.inner).poll_read(cx, buf)
            }
        }

        impl AsyncWrite for UnixStream {
            fn poll_write(
                mut self: Pin<&mut Self>,
                cx: &mut Context<'_>,
                buf: &[u8],
            ) -> Poll<std::io::Result<usize>> {
                Pin::new(&mut self.inner).poll_write(cx, buf)
            }

            fn poll_flush(
                mut self: Pin<&mut Self>,
                cx: &mut Context<'_>,
            ) -> Poll<std::io::Result<()>> {
                Pin::new(&mut self.inner).poll_flush(cx)
            }

            fn poll_shutdown(
                mut self: Pin<&mut Self>,
                cx: &mut Context<'_>,
            ) -> Poll<std::io::Result<()>> {
                Pin::new(&mut self.inner).poll_shutdown(cx)
            }
        }
    }
}