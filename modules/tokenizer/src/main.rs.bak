pub enum Token {
    Number(f64),
    Plus,
    Minus,
    Star,
    Slash,
    Caret,
    LParen,
    RParen,
    Comma,
    Exclamation,
    Question,
    Colon,
    DotDot,
    LShift,
    Gt,
    Lt,
    Percent,
    Sqrt,
    C,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ParseError {
    UnknownPattern,
}

fn main() {}