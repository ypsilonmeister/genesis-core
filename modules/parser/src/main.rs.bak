use crate::compat::UnixListener;
use anyhow::Result;
use chrono::{DateTime, Utc};
use serde::{Deserialize, Serialize};
use std::env;
use std::time::Instant;
use tokio::io::{AsyncBufReadExt, AsyncWriteExt};
use tokio::net::TcpListener;

// =============================================================================
// # CMP Module Charter
//
// What:
//   トークン列を演算子優先度を考慮した抽象構文木 (AST) に変換する。
//
// Invariants:
//   - 演算子優先度: * / は + - より高い
//   - 括弧による優先度変更を正しく処理する
//   - 不正な文法(演算子連続、括弧不一致等)はエラーを返す
//
// Boundaries:
//   - 依存先: tokenizer
//   - 被依存先: evaluator
//
// Extensible:
//   - 新しい演算子・関数呼び出し構文の追加
//
// Why:
//   evaluator が純粋な計算に集中できるよう、文法解析を分離する。
// =============================================================================

const MAX_DEPTH: usize = 128;

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModuleRequest {
    pub request_id: String,
    pub input: String,
    pub timestamp: DateTime<Utc>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModuleResponse {
    pub request_id: String,
    pub output: Option<String>,
    pub error: Option<ModuleError>,
    pub processing_ms: u64,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModuleError {
    pub code: String,
    pub message: String,
    pub input_position: Option<usize>,
}

#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
#[serde(tag = "type", content = "value", rename_all = "snake_case")]
pub enum Token {
    Number(f64),
    Plus,
    Minus,
    Star,
    Slash,
    Caret,
    LParen,
    RParen,
    Comma,
    Exclamation,
    Question,
    Colon,
    DotDot,
    LShift,
    Gt,
    Lt,
    Percent,
    Sqrt,
    Cbrt,
    Function(String),
}

#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
#[serde(tag = "type", content = "value", rename_all = "snake_case")]
pub enum Expr {
    Number(f64),
    BinOp {
        op: BinOp,
        lhs: Box<Expr>,
        rhs: Box<Expr>,
    },
    UnaryOp {
        op: UnaryOp,
        expr: Box<Expr>,
    },
    FunctionCall {
        name: String,
        args: Vec<Expr>,
    },
    Ternary {
        cond: Box<Expr>,
        truthy: Box<Expr>,
        falsy: Box<Expr>,
    },
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
#[serde(rename_all = "SCREAMING_SNAKE_CASE")]
pub enum BinOp {
    Add,
    Sub,
    Mul,
    Div,
    Pow,
    LShift,
    Gt,
    Lt,
    DotDot,
    Mod,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
#[serde(rename_all = "SCREAMING_SNAKE_CASE")]
pub enum UnaryOp {
    Neg,
    Fact,
}

struct Parser {
    tokens: Vec<Token>,
    pos: usize,
}

impl Parser {
    fn new(tokens: Vec<Token>) -> Self {
        Parser { tokens, pos: 0 }
    }

    fn peek(&self) -> Option<&Token> {
        self.tokens.get(self.pos)
    }

    fn next(&mut self) -> Option<Token> {
        let t = self.tokens.get(self.pos).cloned();
        if t.is_some() {
            self.pos += 1;
        }
        t
    }

    fn parse_expression(&mut self, depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        self.parse_ternary(depth + 1)
    }

    fn parse_ternary(&mut self, depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let node = self.parse_range(depth + 1)?;
        if let Some(Token::Question) = self.peek() {
            self.next();
            let truthy = self.parse_expression(depth + 1)?;
            if let Some(Token::Colon) = self.peek() {
                self.next();
                let falsy = self.parse_ternary(depth + 1)?;
                return Ok(Expr::Ternary {
                    cond: Box::new(node),
                    truthy: Box::new(truthy),
                    falsy: Box::new(falsy),
                });
            } else {
                return Err("Expected ':' in ternary operator".to_string());
            }
        }
        Ok(node)
    }

    fn parse_range(&mut self, depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let mut node = self.parse_relational(depth + 1)?;
        if let Some(Token::DotDot) = self.peek() {
            self.next();
            let rhs = self.parse_relational(depth + 1)?;
            node = Expr::BinOp {
                op: BinOp::DotDot,
                lhs: Box::new(node),
                rhs: Box::new(rhs),
            };
        }
        Ok(node)
    }

    fn parse_relational(&mut self, mut depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let mut node = self.parse_shift(depth + 1)?;
        while let Some(t) = self.peek().cloned() {
            match t {
                Token::Gt | Token::Lt => {
                    self.next();
                    depth += 1;
                    if depth > MAX_DEPTH {
                        return Err("Maximum recursion depth exceeded".to_string());
                    }
                    let op = if t == Token::Gt { BinOp::Gt } else { BinOp::Lt };
                    let rhs = self.parse_shift(depth + 1)?;
                    node = Expr::BinOp {
                        op,
                        lhs: Box::new(node),
                        rhs: Box::new(rhs),
                    };
                }
                _ => break,
            }
        }
        Ok(node)
    }

    fn parse_shift(&mut self, mut depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let mut node = self.parse_add_sub(depth + 1)?;
        while let Some(Token::LShift) = self.peek() {
            self.next();
            depth += 1;
            if depth > MAX_DEPTH {
                return Err("Maximum recursion depth exceeded".to_string());
            }
            let rhs = self.parse_add_sub(depth + 1)?;
            node = Expr::BinOp {
                op: BinOp::LShift,
                lhs: Box::new(node),
                rhs: Box::new(rhs),
            };
        }
        Ok(node)
    }

    fn parse_add_sub(&mut self, mut depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let mut node = self.parse_mul_div(depth + 1)?;
        while let Some(t) = self.peek().cloned() {
            match t {
                Token::Plus | Token::Minus => {
                    self.next();
                    depth += 1;
                    if depth > MAX_DEPTH {
                        return Err("Maximum recursion depth exceeded".to_string());
                    }
                    let op = if t == Token::Plus { BinOp::Add } else { BinOp::Sub };
                    let rhs = self.parse_mul_div(depth + 1)?;
                    node = Expr::BinOp {
                        op,
                        lhs: Box::new(node),
                        rhs: Box::new(rhs),
                    };
                }
                _ => break,
            }
        }
        Ok(node)
    }

    fn parse_mul_div(&mut self, mut depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let mut node = self.parse_unary(depth + 1)?;
        while let Some(t) = self.peek().cloned() {
            match t {
                Token::Star => {
                    self.next();
                    depth += 1;
                    if depth > MAX_DEPTH {
                        return Err("Maximum recursion depth exceeded".to_string());
                    }
                    if let Some(Token::Star) = self.peek() {
                        self.next();
                        let rhs = self.parse_unary(depth + 1)?;
                        node = Expr::BinOp {
                            op: BinOp::Pow,
                            lhs: Box::new(node),
                            rhs: Box::new(rhs),
                        };
                    } else {
                        let rhs = self.parse_unary(depth + 1)?;
                        node = Expr::BinOp {
                            op: BinOp::Mul,
                            lhs: Box::new(node),
                            rhs: Box::new(rhs),
                        };
                    }
                }
                Token::Slash | Token::Percent => {
                    self.next();
                    depth += 1;
                    if depth > MAX_DEPTH {
                        return Err("Maximum recursion depth exceeded".to_string());
                    }
                    let op = if t == Token::Slash { BinOp::Div } else { BinOp::Mod };
                    let rhs = self.parse_unary(depth + 1)?;
                    node = Expr::BinOp {
                        op,
                        lhs: Box::new(node),
                        rhs: Box::new(rhs),
                    };
                }
                _ => break,
            }
        }
        Ok(node)
    }

    fn parse_unary(&mut self, depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        match self.peek() {
            Some(Token::Plus) => {
                self.next();
                self.parse_unary(depth + 1)
            }
            Some(Token::Minus) => {
                self.next();
                let expr = self.parse_pow(depth + 1)?;
                Ok(Expr::UnaryOp {
                    op: UnaryOp::Neg,
                    expr: Box::new(expr),
                })
            }
            Some(Token::Sqrt) => {
                self.next();
                let expr = self.parse_pow(depth + 1)?;
                Ok(Expr::FunctionCall {
                    name: "sqrt".to_string(),
                    args: vec![expr],
                })
            }
            Some(Token::Cbrt) => {
                self.next();
                let expr = self.parse_pow(depth + 1)?;
                Ok(Expr::FunctionCall {
                    name: "cbrt".to_string(),
                    args: vec![expr],
                })
            }
            _ => self.parse_pow(depth + 1),
        }
    }

    fn parse_pow(&mut self, depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let mut node = self.parse_postfix(depth + 1)?;
        if let Some(Token::Caret) = self.peek() {
            self.next();
            let rhs = self.parse_pow(depth + 1)?;
            node = Expr::BinOp {
                op: BinOp::Pow,
                lhs: Box::new(node),
                rhs: Box::new(rhs),
            };
        }
        Ok(node)
    }

    fn parse_postfix(&mut self, mut depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let mut node = self.parse_primary(depth + 1)?;
        while let Some(Token::Exclamation) = self.peek() {
            self.next();
            depth += 1;
            if depth > MAX_DEPTH {
                return Err("Maximum recursion depth exceeded".to_string());
            }
            node = Expr::UnaryOp {
                op: UnaryOp::Fact,
                expr: Box::new(node),
            };
        }
        Ok(node)
    }

    fn parse_primary(&mut self, depth: usize) -> Result<Expr, String> {
        if depth > MAX_DEPTH {
            return Err("Maximum recursion depth exceeded".to_string());
        }
        let t = self.peek().cloned();
        match t {
            Some(Token::Number(n)) => {
                self.next();
                Ok(Expr::Number(n))
            }
            Some(Token::LParen) => {
                self.next();
                let node = self.parse_expression(depth + 1)?;
                match self.peek() {
                    Some(Token::RParen) => {
                        self.next();
                        Ok(node)
                    }
                    _ => Err("Missing closing parenthesis".to_string()),
                }
            }
            Some(Token::Function(name)) => {
                self.next();
                match self.peek() {
                    Some(Token::LParen) => {
                        self.next();
                        let mut args = Vec::new();
                        if let Some(Token::RParen) = self.peek() {
                            self.next();
                        } else {
                            loop {
                                args.push(self.parse_expression(depth + 1)?);
                                match self.peek() {
                                    Some(Token::Comma) => {
                                        self.next();
                                        continue;
                                    }
                                    Some(Token::RParen) => {
                                        self.next();
                                        break;
                                    }
                                    _ => return Err("Invalid function call syntax".to_string()),
                                }
                            }
                        }
                        Ok(Expr::FunctionCall { name, args })
                    }
                    _ => Ok(Expr::FunctionCall {
                        name,
                        args: Vec::new(),
                    }),
                }
            }
            Some(tok) => Err(format!("Unexpected token: {:?}", tok)),
            None => Err("Unexpected end of input".to_string()),
        }
    }
}

fn check_for_unknown_patterns(expr: &Expr, depth: usize) -> Option<String> {
    if depth > MAX_DEPTH {
        return Some("Maximum expression depth exceeded".to_string());
    }
    match expr {
        Expr::Number(n) => {
            if n.is_infinite() || n.is_nan() {
                return Some("Invalid number value".to_string());
            }
            if n.fract() != 0.0 {
                return Some("Decimal numbers not supported".to_string());
            }
            None
        }
        Expr::BinOp { op, lhs, rhs } => {
            if let Some(msg) = check_for_unknown_patterns(lhs, depth + 1) {
                return Some(msg);
            }
            if let Some(msg) = check_for_unknown_patterns(rhs, depth + 1) {
                return Some(msg);
            }
            if *op == BinOp::Pow {
                if matches!(**lhs, Expr::BinOp { op: BinOp::Pow, .. })
                    || matches!(**rhs, Expr::BinOp { op: BinOp::Pow, .. })
                {
                    return Some("Nested power operators not supported".to_string());
                }
            }
            match op {
                BinOp::Div => {
                    if let Expr::Number(n) = &**rhs {
                        if *n == 0.0 {
                            return Some("Division by zero not allowed".to_string());
                        }
                        if n.is_infinite() {
                            return Some("Division by infinity not allowed".to_string());
                        }
                    }
                }
                BinOp::Mod => {
                    if let Expr::Number(n) = &**rhs {
                        if *n == 0.0 {
                            return Some("Modulo by zero not allowed".to_string());
                        }
                    }
                }
                _ => {}
            }
            None
        }
        Expr::UnaryOp { op: _, expr } => check_for_unknown_patterns(expr, depth + 1),
        Expr::FunctionCall { name, args } => {
            if args.is_empty() {
                return Some(format!("Variables not supported: {}", name));
            }
            for arg in args {
                if let Some(msg) = check_for_unknown_patterns(arg, depth + 1) {
                    return Some(msg);
                }
            }
            let supported = matches!(
                name.as_str(),
                "log" | "log10" | "log2" | "ln" | "sqrt" | "cbrt" | "asin" | "acos"
            );
            if !supported {
                return Some(format!("Unsupported function: {}", name));
            }
            match name.as_str() {
                "log" | "log10" | "log2" | "ln" => {
                    if let Some(Expr::Number(n)) = args.first() {
                        if *n < 0.0 {
                            return Some(format!("Cannot apply {} to negative number", name));
                        }
                        if *n == 0.0 {
                            return Some(format!("{} of zero is undefined", name));
                        }
                    }
                }
                "sqrt" => {
                    if let Some(Expr::Number(n)) = args.first() {
                        if *n < 0.0 {
                            return Some("Cannot take square root of negative number".to_string());
                        }
                    }
                }
                "asin" | "acos" => {
                    if let Some(Expr::Number(n)) = args.first() {
                        if *n < -1.0 || *n > 1.0 {
                            return Some(format!("Domain error: {} only defined for [-1, 1]", name));
                        }
                    }
                }
                _ => {}
            }
            None
        }
        Expr::Ternary {
            cond,
            truthy,
            falsy,
        } => {
            if let Some(msg) = check_for_unknown_patterns(cond, depth + 1) {
                return Some(msg);
            }
            if let Some(msg) = check_for_unknown_patterns(truthy, depth + 1) {
                return Some(msg);
            }
            if let Some(msg) = check_for_unknown_patterns(falsy, depth + 1) {
                return Some(msg);
            }
            None
        }
    }
}

#[tokio::main]
async fn main() -> Result<()> {
    init_tracing();
    tracing::info!("parser booting (v1.1)");

    let addr_or_path = env::args()
        .nth(1)
        .unwrap_or_else(|| "/tmp/genesis-core/parser.sock".to_string());

    if addr_or_path.starts_with("tcp://") {
        let addr = addr_or_path.strip_prefix("tcp://").unwrap();
        let listener = TcpListener::bind(addr).await?;
        tracing::info!("Listening on TCP {}", addr);
        loop {
            let (stream, _) = match listener.accept().await {
                Ok(s) => s,
                Err(e) => {
                    tracing::error!("Failed to accept TCP connection: {}", e);
                    continue;
                }
            };
            tokio::spawn(async move {
                let _ = handle_client(stream).await;
            });
        }
    } else {
        let uds_path = addr_or_path.strip_prefix("uds://").unwrap_or(&addr_or_path);
        let _ = std::fs::remove_file(uds_path);
        if let Some(parent) = std::path::Path::new(uds_path).parent() {
            let _ = std::fs::create_dir_all(parent);
        }
        let listener = UnixListener::bind(uds_path)?;
        tracing::info!("Listening on UDS {}", uds_path);
        loop {
            let (stream, _) = match listener.accept().await {
                Ok(s) => s,
                Err(e) => {
                    tracing::error!("Failed to accept UDS connection: {}", e);
                    continue;
                }
            };
            tokio::spawn(async move {
                let _ = handle_client(stream).await;
            });
        }
    }
}

async fn handle_client<S>(stream: S) -> Result<()>
where
    S: tokio::io::AsyncRead + tokio::io::AsyncWrite + Unpin + Send + 'static,
{
    let (reader, mut writer) = tokio::io::split(stream);
    let mut reader = tokio::io::BufReader::new(reader);
    let mut line = String::new();

    while let Ok(n) = reader.read_line(&mut line).await {
        if n == 0 {
            break;
        }
        let start = Instant::now();
        let request: ModuleRequest = match serde_json::from_str(&line) {
            Ok(req) => req,
            Err(e) => {
                tracing::error!("Failed to parse request: {}", e);
                line.clear();
                continue;
            }
        };

        let tokens: Vec<Token> = match serde_json::from_str(&request.input) {
            Ok(t) => t,
            Err(e) => {
                send_error(
                    &mut writer,
                    request.request_id,
                    "DESERIALIZE_ERROR",
                    format!("Failed to parse tokens: {}", e),
                    start.elapsed().as_millis() as u64,
                )
                .await;
                line.clear();
                continue;
            }
        };

        let mut parser = Parser::new(tokens);
        let (output, error) = match parser.parse_expression(0) {
            Ok(expr) => {
                if let Some(_t) = parser.peek() {
                    (
                        None,
                        Some(ModuleError {
                            code: "SYNTAX_ERROR".to_string(),
                            message: "Unexpected token after expression".to_string(),
                            input_position: Some(parser.pos),
                        }),
                    )
                } else if let Some(pattern_error) = check_for_unknown_patterns(&expr, 0) {
                    (
                        None,
                        Some(ModuleError {
                            code: "UNKNOWN_PATTERN".to_string(),
                            message: pattern_error,
                            input_position: None,
                        }),
                    )
                } else {
                    match serde_json::to_string(&expr) {
                        Ok(json) => (Some(json), None),
                        Err(e) => (
                            None,
                            Some(ModuleError {
                                code: "SERIALIZE_ERROR".to_string(),
                                message: e.to_string(),
                                input_position: None,
                            }),
                        ),
                    }
                }
            }
            Err(e) => {
                let pos = if parser.pos < parser.tokens.len() {
                    Some(parser.pos)
                } else {
                    None
                };
                (
                    None,
                    Some(ModuleError {
                        code: "SYNTAX_ERROR".to_string(),
                        message: e,
                        input_position: pos,
                    }),
                )
            }
        };

        let response = ModuleResponse {
            request_id: request.request_id,
            output,
            error,
            processing_ms: start.elapsed().as_millis() as u64,
        };

        if let Ok(payload) = serde_json::to_vec(&response) {
            let mut payload = payload;
            payload.push(b'\n');
            let _ = writer.write_all(&payload).await;
        }
        line.clear();
    }
    Ok(())
}

async fn send_error(
    writer: &mut (impl AsyncWriteExt + Unpin),
    request_id: String,
    code: &str,
    message: String,
    processing_ms: u64,
) {
    let response = ModuleResponse {
        request_id,
        output: None,
        error: Some(ModuleError {
            code: code.to_string(),
            message,
            input_position: None,
        }),
        processing_ms,
    };
    if let Ok(payload) = serde_json::to_vec(&response) {
        let mut payload = payload;
        payload.push(b'\n');
        let _ = writer.write_all(&payload).await;
    }
}

fn init_tracing() {
    use tracing_subscriber::EnvFilter;
    let filter =
        EnvFilter::try_from_default_env().unwrap_or_else(|_| EnvFilter::new("info,parser=debug"));
    let _ = tracing_subscriber::fmt().with_env_filter(filter).try_init();
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_parse_simple() {
        let tokens = vec![
            Token::Number(1.0),
            Token::Plus,
            Token::Number(2.0),
            Token::Star,
            Token::Number(3.0),
        ];
        let mut parser = Parser::new(tokens);
        let expr = parser.parse_expression(0).unwrap();
        assert!(matches!(expr, Expr::BinOp { op: BinOp::Add, .. }));
    }

    #[test]
    fn test_parse_parens() {
        let tokens = vec![
            Token::LParen,
            Token::Number(1.0),
            Token::Plus,
            Token::Number(2.0),
            Token::RParen,
            Token::Star,
            Token::Number(3.0),
        ];
        let mut parser = Parser::new(tokens);
        let expr = parser.parse_expression(0).unwrap();
        assert!(matches!(expr, Expr::BinOp { op: BinOp::Mul, .. }));
    }

    #[test]
    fn test_parse_pow() {
        let tokens = vec![
            Token::Number(2.0),
            Token::Caret,
            Token::Number(3.0),
            Token::Caret,
            Token::Number(2.0),
        ];
        let mut parser = Parser::new(tokens);
        let expr = parser.parse_expression(0).unwrap();
        if let Expr::BinOp {
            op: BinOp::Pow,
            rhs,
            ..
        } = expr
        {
            assert!(matches!(*rhs, Expr::BinOp { op: BinOp::Pow, .. }));
        } else {
            panic!("Expected Pow");
        }
    }

    #[test]
    fn test_division_by_zero_detected() {
        let expr = Expr::BinOp {
            op: BinOp::Div,
            lhs: Box::new(Expr::Number(1.0)),
            rhs: Box::new(Expr::Number(0.0)),
        };
        assert!(check_for_unknown_patterns(&expr, 0).is_some());
    }

    #[test]
    fn test_recursion_depth_limit() {
        let mut tokens = Vec::new();
        for _ in 0..200 {
            tokens.push(Token::LParen);
        }
        tokens.push(Token::Number(1.0));
        for _ in 0..200 {
            tokens.push(Token::RParen);
        }
        let mut parser = Parser::new(tokens);
        assert!(parser.parse_expression(0).is_err());
    }
}

pub mod compat {
    #[cfg(windows)]
    pub use windows::*;

    #[cfg(unix)]
    pub use tokio::net::{UnixListener, UnixStream};

    #[cfg(windows)]
    mod windows {
        use std::net::SocketAddr;
        use std::path::Path;
        use std::pin::Pin;
        use std::task::{Context, Poll};
        use tokio::io::{AsyncRead, AsyncWrite, ReadBuf};
        use tokio::net::{TcpListener, TcpStream};

        fn path_to_port(path: impl AsRef<Path>) -> u16 {
            use std::collections::hash_map::DefaultHasher;
            use std::hash::{Hash, Hasher};
            let mut hasher = DefaultHasher::new();
            path.as_ref().to_string_lossy().hash(&mut hasher);
            let hash = hasher.finish();
            (49152 + (hash % 16384)) as u16
        }

        pub struct UnixListener {
            inner: TcpListener,
        }

        impl UnixListener {
            pub fn bind(path: impl AsRef<Path>) -> std::io::Result<Self> {
                let port = path_to_port(path);
                let addr = SocketAddr::from(([127, 0, 0, 1], port));
                let std_listener = std::net::TcpListener::bind(addr)?;
                std_listener.set_nonblocking(true)?;
                let inner = TcpListener::from_std(std_listener)?;
                Ok(Self { inner })
            }

            pub async fn accept(&self) -> std::io::Result<(UnixStream, SocketAddr)> {
                let (stream, addr) = self.inner.accept().await?;
                Ok((UnixStream { inner: stream }, addr))
            }
        }

        pub struct UnixStream {
            inner: TcpStream,
        }

        impl UnixStream {
            pub async fn connect(path: impl AsRef<Path>) -> std::io::Result<Self> {
                let port = path_to_port(path);
                let addr = SocketAddr::from(([127, 0, 0, 1], port));
                let inner = TcpStream::connect(addr).await?;
                Ok(Self { inner })
            }

            pub fn split(self) -> (tokio::io::ReadHalf<Self>, tokio::io::WriteHalf<Self>) {
                tokio::io::split(self)
            }
        }

        impl AsyncRead for UnixStream {
            fn poll_read(
                mut self: Pin<&mut Self>,
                cx: &mut Context<'_>,
                buf: &mut ReadBuf<'_>,
            ) -> Poll<std::io::Result<()>> {
                Pin::new(&mut self.inner).poll_read(cx, buf)
            }
        }

        impl AsyncWrite for UnixStream {
            fn poll_write(
                mut self: Pin<&mut Self>,
                cx: &mut Context<'_>,
                buf: &[u8],
            ) -> Poll<std::io::Result<usize>> {
                Pin::new(&mut self.inner).poll_write(cx, buf)
            }

            fn poll_flush(
                mut self: Pin<&mut Self>,
                cx: &mut Context<'_>,
            ) -> Poll<std::io::Result<()>> {
                Pin::new(&mut self.inner).poll_flush(cx)
            }

            fn poll_shutdown(
                mut self: Pin<&mut Self>,
                cx: &mut Context<'_>,
            ) -> Poll<std::io::Result<()>> {
                Pin::new(&mut self.inner).poll_shutdown(cx)
            }
        }
    }
}